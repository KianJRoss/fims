# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.env.*
!.env.example

# Docker volumes / data
postgres_data/
redis_data/

# Media uploads
media/

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# Generated catalog data (large, regeneratable)
scripts/catalog_pages/
scripts/jakes_catalog_vision.json
scripts/test_pages_26_27.json
scripts/jakes_catalog.json
scripts/jakes_catalog.csv

# Catalog page images (downloaded, regeneratable via extract_catalog.py --slug ... --year ...)
scripts/catalogs/**/pages/
# Keep vision.json outputs and .gitkeep markers
!scripts/catalogs/**/.gitkeep
!scripts/catalogs/**/vision.json

# Raw catalog PDFs and extracted product images (large binaries, regeneratable from the
# source PDF via extract_catalog_images.py / extract_product_images.py -- not needed for
# live operation, only the live media/product_images/ copy is, which is already ignored above)
scripts/catalogs/**/*.pdf
scripts/catalogs/jakes/2026/product_images/

# Celery schedule
backend/celerybeat-schedule

# Health check state
scripts/.health_check_state.json

# DB mesh: local snapshots/dumps (large, machine-local) and sync logs
backups/
scripts/db/*.log

# Staged videos for the Video Pi USB (large, regeneratable via stage_videos.py)
media/videopi_staging/

# Stray git leftover from a previous re-init attempt
.git-temp/
