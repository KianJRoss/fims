:80 {
    # ── Public access via Tailscale Funnel (shop + receipts only) ─────────────
    @public_host host kianpotpi.taile4f97e.ts.net

    handle @public_host {
        # Shop pages — public product browser
        handle /shop* {
            reverse_proxy web:3000 {
                header_up Host {host}
            }
        }

        # Digital receipt pages
        handle /receipt* {
            reverse_proxy web:3000 {
                header_up Host {host}
            }
        }

        # API: products (read-only, shop needs this)
        handle /api/v1/products* {
            uri strip_prefix /api
            reverse_proxy api:8000 {
                flush_interval -1
            }
        }

        # API: categories (shop filter sidebar)
        handle /api/v1/categories* {
            uri strip_prefix /api
            reverse_proxy api:8000 {
                flush_interval -1
            }
        }

        # API: deals (shop home page)
        handle /api/v1/deals/* {
            uri strip_prefix /api
            reverse_proxy api:8000 {
                flush_interval -1
            }
        }

        # API: receipts (QR code token lookup)
        handle /api/v1/receipts/* {
            uri strip_prefix /api
            reverse_proxy api:8000 {
                flush_interval -1
            }
        }

        # Static media (product images)
        handle /media/* {
            uri strip_prefix /media
            root * /app/media
            file_server
        }

        # Block everything else from public internet
        handle {
            respond 403
        }
    }

    # ── LAN access (store WiFi — full FIMS) ───────────────────────────────────

    # API - FastAPI
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    # WebSocket for live kiosk push (Pi display, barcode events)
    handle /ws/* {
        reverse_proxy api:8000
    }

    # Static media (product images, videos)
    handle /media/* {
        uri strip_prefix /media
        root * /app/media
        file_server
    }

    # External video files served from the dedicated video Pi storage
    handle /external-videos/* {
        root * /srv/external-videos
        rewrite * {path.file}
        file_server
    }

    # Everything else - React SPA
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
        }
    }
}
