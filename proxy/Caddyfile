:80 {
    # ── Public access via Tailscale Funnel (shop + receipts only) ─────────────
    @public_shop {
        host kianpotpi.taile4f97e.ts.net
        path /shop*
    }
    handle @public_shop {
        reverse_proxy web:3000 {
            header_up Host {host}
        }
    }

    @public_receipt {
        host kianpotpi.taile4f97e.ts.net
        path /receipt*
    }
    handle @public_receipt {
        reverse_proxy web:3000 {
            header_up Host {host}
        }
    }

    @public_products {
        host kianpotpi.taile4f97e.ts.net
        method GET
        path /api/v1/products*
    }
    handle @public_products {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    @public_categories {
        host kianpotpi.taile4f97e.ts.net
        method GET
        path /api/v1/categories*
    }
    handle @public_categories {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    @public_deals {
        host kianpotpi.taile4f97e.ts.net
        method GET
        path /api/v1/deals/*
    }
    handle @public_deals {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    @public_receipts {
        host kianpotpi.taile4f97e.ts.net
        method GET
        path /api/v1/receipts/*
    }
    handle @public_receipts {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    @public_media {
        host kianpotpi.taile4f97e.ts.net
        method GET
        path /media/product_images/*
    }
    handle @public_media {
        uri strip_prefix /media
        root * /app/media
        file_server
    }

    @public_host {
        host kianpotpi.taile4f97e.ts.net
    }
    handle @public_host {
        respond 403
    }

    # ── LAN access (store WiFi — full FIMS) ───────────────────────────────────

    # API - FastAPI
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    # WebSocket for live kiosk push (Pi display, barcode events)
    handle /ws/* {
        reverse_proxy api:8000
    }

    # Static media (product images, videos)
    handle /media/* {
        uri strip_prefix /media
        root * /app/media
        file_server
    }

    # External video files served from the dedicated video Pi storage
    handle /external-videos/* {
        root * /srv/external-videos
        rewrite * {path.file}
        file_server
    }

    # Everything else - React SPA
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
        }
    }
}
