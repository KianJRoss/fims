# Normalize all text files to LF in the repo (production runs on Linux).
# Prevents CRLF<->LF churn when committing from Windows clones (laptop/PC).
* text=auto eol=lf

# Explicit binaries (never touch)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.mp4 binary
*.gz binary
*.zip binary
